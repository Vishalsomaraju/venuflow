rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStaffOrAdmin() {
      return isSignedIn() && userRole() in ['staff', 'admin'];
    }

    // Zones — fully public read
    match /zones/{id} {
      allow read:  if true;
      allow write: if isStaffOrAdmin();
    }

    // Facilities — fully public read
    match /facilities/{id} {
      allow read:  if true;
      allow write: if isStaffOrAdmin();
    }

    // Alerts — any signed-in user (anonymous counts)
    match /alerts/{id} {
      allow read:  if isSignedIn();
      allow write: if isStaffOrAdmin();
    }

    // Users
    match /users/{uid} {
      allow read:  if isSignedIn() && (request.auth.uid == uid || isStaffOrAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
    }
  }
}
